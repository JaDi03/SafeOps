# SafeOps -- Environment Configuration

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: VEEA Lobster Trap (prompt security)
LOBSTER_TRAP_ENABLED=false
LOBSTER_TRAP_URL=http://localhost:8080

# Optional: X402 Machine-to-Machine Payments
X402_ENABLED=false
X402_WALLET_ADDRESS=your_wallet_address
X402_NETWORK=base

# Server
HOST=0.0.0.0
PORT=8000

# Safety thresholds
RISK_THRESHOLD_HIGH=75
RISK_THRESHOLD_MEDIUM=40
ANALYSIS_INTERVAL_MS=3000
